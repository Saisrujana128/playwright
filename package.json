{
  "name": "web-playwright-starter",
  "version": "1.0.0",
  "description": "A minimal web Playwright starter project with Page Object Model and example tests",
  "repository": {
    "type": "git",
    "url": "https://github.com/PGEDigitalCatalyst/web-playwright-starter.git"
  },
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headless": "npx playwright test -- --headedless=true",
    "test:report": "npx playwright show-report",
    "install:all": "npm install && npx playwright install",
    "allure:generate": "npx allure generate allure-results --clean -o allure-report",
    "allure:open": "npx allure open allure-report",
    "allure:serve": "npx allure serve allure-results",
    "allure:clean": "rm -rf allure-results allure-report",
    "allure:build": "npm run allure:generate",
    "allure:classic": "npm run allure:generate && npm run allure:open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/exceljs": "^0.5.3",
    "@types/node": "^20.11.4",
    "@types/prompt-sync": "^4.2.3",
    "@types/vscode": "^1.109.0",
    "allure-commandline": "2.36.0",
    "allure-playwright": "^3.4.3",
    "dotenv": "^16.1.4",
    "exceljs": "^4.4.0",
    "undici": "^7.21.0"
  },
  "dependencies": {
    "@types/nodemailer": "^7.0.9",
    "nodemailer": "^8.0.1",
    "playwright": "^1.57.0",
    "prompt-sync": "^4.2.0"
  }
}
